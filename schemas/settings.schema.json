{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/wangdiandao/widget-workshop-dev/schemas/settings.schema.json",
  "title": "Widget Workshop component settings schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "fields"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "fields": { "type": "array", "items": { "$ref": "#/$defs/field" } }
  },
  "$defs": {
    "localizedLabel": { "type": "object", "minProperties": 1, "additionalProperties": { "type": "string", "minLength": 1 } },
    "option": { "type": "object", "additionalProperties": false, "required": ["value", "label"], "properties": { "value": { "type": ["string", "number", "boolean"] }, "label": { "$ref": "#/$defs/localizedLabel" } } },
    "field": {
      "type": "object",
      "additionalProperties": true,
      "required": ["key", "label", "type", "control", "default"],
      "properties": {
        "key": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9_-]*$" },
        "label": { "$ref": "#/$defs/localizedLabel" },
        "type": { "enum": ["string", "number", "boolean", "color", "file"] },
        "control": { "enum": ["text", "textarea", "select", "segmented", "number", "slider", "toggle", "checkbox", "color", "file"] },
        "default": {},
        "options": { "type": "array", "items": { "$ref": "#/$defs/option" } },
        "min": { "type": "number" },
        "max": { "type": "number" },
        "step": { "type": "number" },
        "extensions": { "type": "array", "items": { "type": "string", "pattern": "^\\.[A-Za-z0-9]+$" } }
      }
    }
  }
}